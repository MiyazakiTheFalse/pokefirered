    .string "[ROCKETOPS:C2] Milestone logged. Silph\n"
    .string "chain archived for Viridian transfer.$"


SilphCo_11F_Text_MemoryExitBlocked::
    .string "[MEMORY] The projection destabilizes\n"
    .string "outside mission bounds.$"

