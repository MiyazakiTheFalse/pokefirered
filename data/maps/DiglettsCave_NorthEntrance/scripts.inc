DiglettsCave_NorthEntrance_MapScripts::
	map_script MAP_SCRIPT_ON_TRANSITION, DiglettsCave_NorthEntrance_OnTransition
	.byte 0

DiglettsCave_NorthEntrance_OnTransition::
	specialvar VAR_RESULT, ValidateGiovanniInteractionOverlayForCurrentMap
	goto_if_eq VAR_RESULT, FALSE, EventScript_Return
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, DiglettsCave_NorthEntrance_EventScript_MemoryRoutingCheck
	goto_if_eq VAR_MODE_GIOVANNI_MEMORY, FALSE, DiglettsCave_NorthEntrance_EventScript_MemoryRoutingSkip
	goto DiglettsCave_NorthEntrance_EventScript_MemoryDesyncReturnToHub

DiglettsCave_NorthEntrance_EventScript_MemoryRoutingCheck::
	goto_if_eq VAR_MODE_GIOVANNI_MEMORY, FALSE, DiglettsCave_NorthEntrance_EventScript_MemoryDesyncReturnToHub
	goto_if_ne VAR_CHAPTER_ID, 1, DiglettsCave_NorthEntrance_EventScript_MemoryDesyncReturnToHub
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, DiglettsCave_NorthEntrance_EventScript_MemoryObjectiveBegin

DiglettsCave_NorthEntrance_EventScript_MemoryRoutingSkip::
	end

DiglettsCave_NorthEntrance_EventScript_MemoryDesyncReturnToHub::
	warp MAP_ROCKET_HIDEOUT_B4F, 19, 6
	waitstate
	end

DiglettsCave_NorthEntrance_EventScript_MemoryObjectiveBegin::
	setflag FLAG_GIO_MEM_CH1_STARTED
	setvar VAR_GIO_CHAPTER, 1
	end

DiglettsCave_NorthEntrance_EventScript_Hiker::
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, DiglettsCave_NorthEntrance_EventScript_HikerMemory
	msgbox DiglettsCave_NorthEntrance_RockTunnelPitchBlack, MSGBOX_NPC
	end

DiglettsCave_NorthEntrance_EventScript_HikerMemory::
	msgbox DiglettsCave_NorthEntrance_Text_MemoryLogisticsBriefing, MSGBOX_NPC
	end

DiglettsCave_NorthEntrance_EventScript_MemoryExitGuard::
	setvar VAR_0x8004, 1
	call EventScript_GiovanniSharedWarp_ResolvePrecedence
	goto_if_eq VAR_RESULT, GIO_SHARED_WARP_RESULT_NORMAL_ROUTE, EventScript_Nothing
	goto_if_eq VAR_RESULT, GIO_SHARED_WARP_RESULT_LOCKED_FALLBACK, DiglettsCave_NorthEntrance_EventScript_MemoryDesyncReturnToHub
	lockall
	msgbox DiglettsCave_NorthEntrance_Text_MemoryExitBlocked
	warp MAP_DIGLETTS_CAVE_B1F, 3, 4
	waitstate
	releaseall
	end

DiglettsCave_NorthEntrance_EventScript_MemoryExitGuard_Mismatch::
	lockall
	msgbox DiglettsCave_NorthEntrance_Text_MemoryChapterMismatch
	warp MAP_DIGLETTS_CAVE_B1F, 3, 4
	waitstate
	releaseall
	end
