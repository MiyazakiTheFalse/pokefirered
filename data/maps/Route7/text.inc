Route7_Text_SurgeErikaIntro::
    .string "SURGE: Halt! That east gate's a choke\n"
    .string "point, and ROCKET scouts love it.\p"
    .string "ERIKA: Lavender's been unsettled lately.\n"
    .string "Before you go on, prove your teamwork.$"

Route7_Text_SurgeErikaDefeat::
    .string "SURGE: Hah! That's real battle rhythm!\p"
    .string "ERIKA: Your bond held steady under\n"
    .string "pressure. Splendid.$"

Route7_Text_SurgeErikaNotEnoughMons::
    .string "ERIKA: A doubles check requires two\n"
    .string "healthy POK\xE9MON. Return prepared.$"

Route7_Text_ReceivedMiracleSeedFromSurgeAndErika::
    .string "You received a MIRACLE SEED\n"
    .string "from SURGE and ERIKA.$"

Route7_Text_NoRoomForMiracleSeed::
    .string "SURGE: Bag jammed, kid. Make space\n"
    .string "and we'll hand it over.$"

Route7_Text_SurgeErikaPostBattle::
    .string "SURGE: Route's clear--shortcut's open.\n"
    .string "Move quick and keep your guard up!\p"
    .string "ERIKA: In Lavender, be gentle with the\n"
    .string "restless spirits and watch for ROCKET.$"

Route7_Text_UnderpassGuard::
    .string "Access is restricted. LT. SURGE and\n"
    .string "ERIKA are screening travelers first.$"

Route7_Text_UndergroundPathSign::
    .string "UNDERGROUND PATH\n"
    .string "Closed pending ROUTE 7 security\l"
    .string "inspection.\p"
    .string "CELADON CITY - LAVENDER TOWN$"

Route7_Text_UndergroundPathSignOpen::
    .string "UNDERGROUND PATH\n"
    .string "Clearance granted after ROUTE 7\l"
    .string "inspection.\p"
    .string "CELADON CITY - LAVENDER TOWN$"
