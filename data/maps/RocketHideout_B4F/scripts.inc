.equ NUM_DOOR_GRUNTS_DEFEATED, VAR_TEMP_1

RocketHideout_B4F_MapScripts::
	map_script MAP_SCRIPT_ON_LOAD, RocketHideout_B4F_OnLoad
	map_script MAP_SCRIPT_ON_TRANSITION, RocketHideout_B4F_OnTransition
	.byte 0

RocketHideout_B4F_OnTransition::
	specialvar VAR_RESULT, ValidateGiovanniInteractionOverlayForCurrentMap
	goto_if_eq VAR_RESULT, FALSE, EventScript_Return
	goto_if_unset FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, RocketHideout_B4F_EventScript_SkipMemoryRoutingCheck
	goto_if_eq VAR_MODE_GIOVANNI_MEMORY, FALSE, RocketHideout_B4F_EventScript_MemoryDesyncReturnToHub
	goto_if_ne VAR_CHAPTER_ID, 1, RocketHideout_B4F_EventScript_MemoryDesyncReturnToHub
	goto_if_set FLAG_GIO_MEM_CH1_COMPLETE, RocketHideout_B4F_EventScript_MemoryDesyncReturnToHub
	goto_if_set FLAG_GIO_MEM_CH2_COMPLETE, RocketHideout_B4F_EventScript_MemoryDesyncReturnToHub
	goto_if_set FLAG_GIO_MEM_CH3_COMPLETE, RocketHideout_B4F_EventScript_MemoryDesyncReturnToHub
	end

RocketHideout_B4F_EventScript_SkipMemoryRoutingCheck::
	end

RocketHideout_B4F_EventScript_MemoryDesyncReturnToHub::
	warp MAP_ROCKET_HIDEOUT_B4F, 19, 6
	waitstate
	end

RocketHideout_B4F_EventScript_MemorySpaceMarker::
	goto_if_ne VAR_CHAPTER_ID, 1, RocketHideout_B4F_EventScript_MemoryChapterMismatchMarker
	goto_if_set FLAG_GIO_MEM_CH1_COMPLETE, RocketHideout_B4F_EventScript_MemorySpaceMarkerComplete
	msgbox RocketHideout_B4F_Text_MemoryChapterIntro, MSGBOX_AUTOCLOSE
	end

RocketHideout_B4F_EventScript_MemorySpaceMarkerComplete::
	msgbox RocketHideout_B4F_Text_MemorySpaceMarker, MSGBOX_AUTOCLOSE
	end

RocketHideout_B4F_EventScript_MemoryChapterMismatchMarker::
	msgbox RocketHideout_B4F_Text_MemoryChapterMismatch, MSGBOX_AUTOCLOSE
	end

RocketHideout_B4F_EventScript_MemoryMedicTerminal::
	setvar VAR_0x8005, 1 @ ROCKETOPS_TRIGGER_CONTROL_NODE
	goto EventScript_RocketOps_Terminal

EventScript_RocketOps_Command_SecureRoute_C1::
	setflag FLAG_ROCKETOPS_ORDER_SECURE_CORRIDOR
	call RocketHideout_B4F_EventScript_RemoveBarrier
	special DrawWholeMapView
	msgbox RocketHideout_B4F_Text_RocketOps_SecureRoute_C1
	msgbox RocketHideout_B4F_Text_RocketOps_StatusReport_SecureCorridor_C1, MSGBOX_AUTOCLOSE
	goto EventScript_RocketOps_CommandFinalize

EventScript_RocketOps_Command_DeployAgent_C1::
	setflag FLAG_ROCKETOPS_ORDER_HOLD_POSITION
	msgbox RocketHideout_B4F_Text_RocketOps_DeployAgent_C1
	msgbox RocketHideout_B4F_Text_RocketOps_StatusReport_HoldPosition_C1, MSGBOX_AUTOCLOSE
	goto EventScript_RocketOps_CommandFinalize

EventScript_RocketOps_Command_DestroyData_C1::
	setflag FLAG_ROCKETOPS_ORDER_OPEN_ROUTE
	msgbox RocketHideout_B4F_Text_RocketOps_DestroyData_C1
	msgbox RocketHideout_B4F_Text_RocketOps_StatusReport_OpenRoute_C1, MSGBOX_AUTOCLOSE
	goto EventScript_RocketOps_CommandFinalize

EventScript_RocketOps_Command_ExtractStaff_C1::
	msgbox RocketHideout_B4F_Text_RocketOps_ExtractStaff_C1
	special HealPlayerParty
	goto EventScript_RocketOps_CommandFinalize

RocketHideout_B4F_OnLoad::
	setvar NUM_DOOR_GRUNTS_DEFEATED, 0
	call_if_defeated TRAINER_TEAM_ROCKET_GRUNT_16, RocketHideout_B4F_EventScript_CountGruntDefeated
	call_if_defeated TRAINER_TEAM_ROCKET_GRUNT_17, RocketHideout_B4F_EventScript_CountGruntDefeated
	goto_if_set FLAG_ROCKETOPS_ORDER_SECURE_CORRIDOR, RocketHideout_B4F_OnLoad_End
	call_if_ne NUM_DOOR_GRUNTS_DEFEATED, 2, RocketHideout_B4F_EventScript_SetBarrier
RocketHideout_B4F_OnLoad_End::
	end

RocketHideout_B4F_EventScript_CountGruntDefeated::
	addvar NUM_DOOR_GRUNTS_DEFEATED, 1
	return

RocketHideout_B4F_EventScript_Giovanni::
	lock
	faceplayer
	famechecker FAMECHECKER_GIOVANNI, 0
	message RocketHideout_B4F_Text_GiovanniIntro
	waitmessage
	playbgm MUS_ENCOUNTER_ROCKET, 0
	waitbuttonpress
	trainerbattle_no_intro TRAINER_BOSS_GIOVANNI, RocketHideout_B4F_Text_GiovanniDefeat
	msgbox RocketHideout_B4F_Text_GiovanniPostBattle
	fadescreen FADE_TO_BLACK
	closemessage
	removeobject LOCALID_HIDEOUT_GIOVANNI
	addobject LOCALID_SILPH_SCOPE
	clearflag FLAG_HIDE_SILPH_SCOPE
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, RocketHideout_B4F_EventScript_SetMemoryCeladonOutcome
	setflag FLAG_HIDE_CELADON_ROCKETS
	famechecker FAMECHECKER_GIOVANNI, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005
	fadescreen FADE_FROM_BLACK
	release
	end

RocketHideout_B4F_EventScript_SetMemoryCeladonOutcome::
	call_if_set FLAG_ROCKETOPS_MILESTONE_CH1_LOGGED, RocketHideout_B4F_EventScript_RocketOpsMilestoneConfirm
	msgbox RocketHideout_B4F_Text_MemoryChapterOutro, MSGBOX_AUTOCLOSE
	closemessage
	setflag FLAG_GIO_MEM_CH1_COMPLETE
	setflag FLAG_GIO_MEM_CH2_STARTED
	setvar VAR_GIO_CHAPTER, 2
	setflag FLAG_GIO_MEM_HIDE_CELADON_ROCKETS
	special SetGiovanniMemoryModePartyForCurrentChapter
	special SyncGiovanniMemoryModeNpcState
	setdynamicwarp MAP_SILPH_CO_11F, 5, 14
	return

RocketHideout_B4F_EventScript_RocketOpsMilestoneConfirm::
	msgbox RocketHideout_B4F_Text_RocketOps_MilestoneLogged_C1, MSGBOX_AUTOCLOSE
	return

RocketHideout_B4F_EventScript_SilphScope::
	lock
	faceplayer
	removeobject LOCALID_SILPH_SCOPE
	giveitem ITEM_SILPH_SCOPE
	goto_if_eq VAR_RESULT, FALSE, EventScript_BagIsFull
	release
	end

RocketHideout_B4F_EventScript_Grunt1::
	trainerbattle_single TRAINER_TEAM_ROCKET_GRUNT_18, RocketHideout_B4F_Text_Grunt1Intro, RocketHideout_B4F_Text_Grunt1Defeat, RocketHideout_B4F_EventScript_DefeatedGrunt1
	msgbox RocketHideout_B4F_Text_Grunt1PostBattle
	release
	end

RocketHideout_B4F_EventScript_DefeatedGrunt1::
	msgbox RocketHideout_B4F_Text_Grunt1PostBattle
	addobject LOCALID_LIFT_KEY
	clearflag FLAG_HIDE_LIFT_KEY
	release
	end

RocketHideout_B4F_EventScript_LiftKey::
	lock
	faceplayer
	setflag FLAG_CAN_USE_ROCKET_HIDEOUT_LIFT
	removeobject LOCALID_LIFT_KEY
	giveitem ITEM_LIFT_KEY
	goto_if_eq VAR_RESULT, FALSE, EventScript_BagIsFull
	release
	end

RocketHideout_B4F_EventScript_Grunt2::
	trainerbattle_single TRAINER_TEAM_ROCKET_GRUNT_16, RocketHideout_B4F_Text_Grunt2Intro, RocketHideout_B4F_Text_Grunt2Defeat, RocketHideout_B4F_EventScript_DefeatedGrunt2
	goto_if_unset FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, RocketHideout_B4F_EventScript_Grunt2PostBattleNormal
	goto_if_ne VAR_CHAPTER_ID, 1, RocketHideout_B4F_EventScript_Grunt2PostBattleNormal
	goto_if_set FLAG_GIO_MEM_CH1_COMPLETE, RocketHideout_B4F_EventScript_Grunt2PostBattleReportDone
	msgbox RocketHideout_B4F_Text_GruntReport_ObjectiveLive, MSGBOX_AUTOCLOSE
	end

RocketHideout_B4F_EventScript_Grunt2PostBattleNormal::
	msgbox RocketHideout_B4F_Text_Grunt2PostBattle, MSGBOX_AUTOCLOSE
	end

RocketHideout_B4F_EventScript_Grunt2PostBattleReportDone::
	msgbox RocketHideout_B4F_Text_GruntReport_ObjectiveDone, MSGBOX_AUTOCLOSE
	end

RocketHideout_B4F_EventScript_DefeatedGrunt2::
	setvar NUM_DOOR_GRUNTS_DEFEATED, 0
	call_if_defeated TRAINER_TEAM_ROCKET_GRUNT_16, RocketHideout_B4F_EventScript_CountGruntDefeated
	call_if_defeated TRAINER_TEAM_ROCKET_GRUNT_17, RocketHideout_B4F_EventScript_CountGruntDefeated
	call_if_eq NUM_DOOR_GRUNTS_DEFEATED, 2, RocketHideout_B4F_EventScript_RemoveBarrier
	call_if_eq NUM_DOOR_GRUNTS_DEFEATED, 2, RocketHideout_B4F_EventScript_DrawMapForBarrierRemoval
	release
	end

RocketHideout_B4F_EventScript_Grunt3::
	trainerbattle_single TRAINER_TEAM_ROCKET_GRUNT_17, RocketHideout_B4F_Text_Grunt3Intro, RocketHideout_B4F_Text_Grunt3Defeat, RocketHideout_B4F_EventScript_DefeatedGrunt3
	msgbox RocketHideout_B4F_Text_Grunt3PostBattle, MSGBOX_AUTOCLOSE
	end

RocketHideout_B4F_EventScript_DefeatedGrunt3::
	setvar NUM_DOOR_GRUNTS_DEFEATED, 0
	call_if_defeated TRAINER_TEAM_ROCKET_GRUNT_16, RocketHideout_B4F_EventScript_CountGruntDefeated
	call_if_defeated TRAINER_TEAM_ROCKET_GRUNT_17, RocketHideout_B4F_EventScript_CountGruntDefeated
	call_if_eq NUM_DOOR_GRUNTS_DEFEATED, 2, RocketHideout_B4F_EventScript_RemoveBarrier
	call_if_eq NUM_DOOR_GRUNTS_DEFEATED, 2, RocketHideout_B4F_EventScript_DrawMapForBarrierRemoval
	release
	end

RocketHideout_B4F_EventScript_DrawMapForBarrierRemoval::
	playse SE_UNLOCK
	special DrawWholeMapView
	waitse
	return

RocketHideout_B4F_EventScript_SetBarrier::
	setmetatile 17, 12, METATILE_SilphCo_HideoutBarrier_TopLeft_Floor, 1
	setmetatile 18, 12, METATILE_SilphCo_HideoutBarrier_TopRight_Floor, 1
	setmetatile 17, 13, METATILE_SilphCo_HideoutBarrier_BottomLeft, 1
	setmetatile 18, 13, METATILE_SilphCo_HideoutBarrier_BottomRight, 1
	setmetatile 17, 14, METATILE_SilphCo_HideoutFloor_ShadeFull, 0
	setmetatile 18, 14, METATILE_SilphCo_HideoutFloor_ShadeFull, 0
	return

RocketHideout_B4F_EventScript_RemoveBarrier::
	setmetatile 17, 12, METATILE_SilphCo_HideoutFloor_ShadeFull, 0
	setmetatile 18, 12, METATILE_SilphCo_HideoutFloor, 0
	setmetatile 17, 13, METATILE_SilphCo_HideoutFloor_ShadeFull, 0
	setmetatile 18, 13, METATILE_SilphCo_HideoutFloor, 0
	setmetatile 17, 14, METATILE_SilphCo_HideoutFloor_ShadeFull, 0
	setmetatile 18, 14, METATILE_SilphCo_HideoutFloor, 0
	return

RocketHideout_B4F_EventScript_MemoryExitGuard::
	setvar VAR_0x8004, 1
	call EventScript_GiovanniSharedWarp_ResolvePrecedence
	goto_if_eq VAR_RESULT, GIO_SHARED_WARP_RESULT_NORMAL_ROUTE, EventScript_Nothing
	goto_if_eq VAR_RESULT, GIO_SHARED_WARP_RESULT_LOCKED_FALLBACK, RocketHideout_B4F_EventScript_MemoryDesyncReturnToHub
	lockall
	msgbox RocketHideout_B4F_Text_MemoryExitBlocked
	warp MAP_ROCKET_HIDEOUT_B4F, 19, 6
	waitstate
	releaseall
	end

RocketHideout_B4F_EventScript_MemoryExitGuard_Mismatch::
	lockall
	msgbox RocketHideout_B4F_Text_MemoryChapterMismatch
	warp MAP_ROCKET_HIDEOUT_B4F, 19, 6
	waitstate
	releaseall
	end
