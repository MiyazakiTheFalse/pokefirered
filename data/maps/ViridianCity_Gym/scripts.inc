ViridianCity_Gym_MapScripts::
	map_script MAP_SCRIPT_ON_TRANSITION, ViridianCity_Gym_OnTransition
	.byte 0

ViridianCity_Gym_OnTransition::
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, ViridianCity_Gym_EventScript_MemoryRoutingCheck
	goto_if_eq VAR_MODE_GIOVANNI_MEMORY, FALSE, ViridianCity_Gym_EventScript_SkipMemoryRoutingCheck
	goto ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub

ViridianCity_Gym_EventScript_MemoryRoutingCheck::
	goto_if_eq VAR_MODE_GIOVANNI_MEMORY, FALSE, ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub
	goto_if_ne VAR_CHAPTER_ID, 3, ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub
	goto_if_unset FLAG_GIO_MEM_CH1_COMPLETE, ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub
	goto_if_unset FLAG_GIO_MEM_CH2_COMPLETE, ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, ViridianCity_Gym_EventScript_RestoreGiovanniMemoryModeOnTransition

ViridianCity_Gym_EventScript_SkipMemoryRoutingCheck::
	end

ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub::
	warp MAP_VIRIDIAN_CITY_GYM, 17, 21
	waitstate
	end

ViridianCity_Gym_EventScript_RestoreGiovanniMemoryModeOnTransition::
	special RestoreGiovanniMemoryModeSnapshot
	special ClearGiovanniMemoryModeCaptureLock
	end

ViridianCity_Gym_EventScript_Giovanni::
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, ViridianCity_Gym_EventScript_MemorySpaceMarker
	lockall
	famechecker FAMECHECKER_GIOVANNI, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005
	setvar VAR_0x8004, 4
	specialvar VAR_RESULT, GetCorpseRunFieldBlockReason
	goto_if_ne VAR_RESULT, 0, EventScript_CorpseRun_GymBattleBlocked
	specialvar VAR_RESULT, StartGiovanniMemoryMode
	goto_if_eq VAR_RESULT, FALSE, ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	special SetGiovanniMemoryModeChapter3Complete
	specialvar VAR_RESULT, RestoreGiovanniMemoryModeSnapshot
	goto_if_eq VAR_RESULT, FALSE, ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	specialvar VAR_RESULT, IsGiovanniMemoryModeReadyForBattle
	goto_if_eq VAR_RESULT, FALSE, ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	trainerbattle_single TRAINER_LEADER_GIOVANNI, ViridianCity_Gym_Text_GiovanniIntro, ViridianCity_Gym_Text_GiovanniDefeat, ViridianCity_Gym_EventScript_DefeatedGiovanni, NO_MUSIC
	goto_if_set FLAG_GIO_MEM_CH3_COMPLETE, ViridianCity_Gym_EventScript_GiovanniMemoryPostBattle
	goto_if_unset FLAG_GOT_TM26_FROM_GIOVANNI, ViridianCity_Gym_EventScript_GiveTM26
	msgbox ViridianCity_Gym_Text_GiovanniPostBattle
	closemessage
	fadescreen FADE_TO_BLACK
	removeobject LOCALID_VIRIDIAN_GIOVANNI
	fadescreen FADE_FROM_BLACK
	release
	end


ViridianCity_Gym_EventScript_MemorySpaceMarker::
	msgbox ViridianCity_Gym_Text_MemorySpaceMarker, MSGBOX_AUTOCLOSE
	return

ViridianCity_Gym_EventScript_MemoryExitGuard::
	goto_if_unset FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, EventScript_Nothing
	goto_if_eq VAR_MODE_GIOVANNI_MEMORY, FALSE, ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub
	goto_if_ne VAR_CHAPTER_ID, 3, ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub
	lockall
	msgbox ViridianCity_Gym_Text_MemoryExitBlocked
	warp MAP_VIRIDIAN_CITY_GYM, 17, 21
	waitstate
	releaseall
	end

ViridianCity_Gym_EventScript_GiovanniMemoryPostBattle::
	msgbox ViridianCity_Gym_Text_GiovanniPostBattle
	closemessage
	fadescreen FADE_TO_BLACK
	removeobject LOCALID_VIRIDIAN_GIOVANNI
	fadescreen FADE_FROM_BLACK
	special ValidateGiovanniMemoryModeRocketFlags
	special ReconcileGiovanniMemoryModeOutcome
	release
	end

ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode::
	special AbortGiovanniMemoryMode
	special ClearGiovanniMemoryModeCaptureLock
	special RestoreGiovanniMemoryModeSnapshot
	special ReconcileGiovanniMemoryModeOutcome
	release
	end

ViridianCity_Gym_EventScript_DefeatedGiovanni::
	goto_if_set FLAG_GIO_MEM_CH3_COMPLETE, ViridianCity_Gym_EventScript_DefeatedGiovanniMemory
	famechecker FAMECHECKER_GIOVANNI, 3
	setflag FLAG_HIDE_MISC_KANTO_ROCKETS
	setflag FLAG_DEFEATED_LEADER_GIOVANNI
	setflag FLAG_BADGE08_GET
	setvar VAR_MAP_SCENE_ROUTE22, 3
	set_gym_trainers 8
	goto ViridianCity_Gym_EventScript_GiveTM26
	end

ViridianCity_Gym_EventScript_DefeatedGiovanniMemory::
	return

ViridianCity_Gym_EventScript_GiveTM26::
	msgbox ViridianCity_Gym_Text_ExplainEarthBadgeTakeThis
	checkitemspace ITEM_TM26
	goto_if_eq VAR_RESULT, FALSE, ViridianCity_Gym_EventScript_NoRoomForTM26
	giveitem_msg ViridianCity_Gym_Text_ReceivedTM26FromGiovanni, ITEM_TM26
	setflag FLAG_GOT_TM26_FROM_GIOVANNI
	msgbox ViridianCity_Gym_Text_ExplainTM26
	special ClearGiovanniMemoryModeCaptureLock
	release
	end

ViridianCity_Gym_EventScript_NoRoomForTM26::
	msgbox ViridianCity_Gym_Text_YouDoNotHaveSpace
	special ClearGiovanniMemoryModeCaptureLock
	release
	end

