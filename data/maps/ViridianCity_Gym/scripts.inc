ViridianCity_Gym_EventScript_Giovanni::
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_ACTIVE, ViridianCity_Gym_EventScript_MemorySpaceMarker
	lockall
	famechecker FAMECHECKER_GIOVANNI, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005
	setvar VAR_0x8004, 4
	specialvar VAR_RESULT, GetCorpseRunFieldBlockReason
	goto_if_ne VAR_RESULT, 0, EventScript_CorpseRun_GymBattleBlocked
	goto_if_set FLAG_SYS_GIOVANNI_MEMORY_MODE_CHAPTER3_COMPLETE, ViridianCity_Gym_EventScript_GiovanniMemoryTransitionCadence
	call ViridianCity_Gym_EventScript_GiovanniPreBattlePrereqCheck
	specialvar VAR_RESULT, StartGiovanniMemoryMode
	goto_if_eq VAR_RESULT, FALSE, ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	fadescreen FADE_TO_BLACK
	warp MAP_ROCKET_HIDEOUT_B4F, 18, 6
	waitstate
	release
	end

ViridianCity_Gym_EventScript_GiovanniPreBattlePrereqCheck::
	setvar VAR_0x8004, 0
	specialvar VAR_RESULT, IsGiovanniNarrativeBeatReadySpecial
	goto_if_eq VAR_RESULT, TRUE, EventScript_Return
	setvar VAR_0x8004, 0
	specialvar VAR_RESULT, GetGiovanniNarrativeBeatFallbackChapterSpecial
	goto_if_eq VAR_RESULT, 1, ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	goto ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	return

ViridianCity_Gym_EventScript_GiovanniStartBattle::
	setvar VAR_0x8004, 4
	specialvar VAR_RESULT, IsGiovanniNarrativeBeatReadySpecial
	goto_if_eq VAR_RESULT, FALSE, ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	specialvar VAR_RESULT, IsGiovanniMemoryModeReadyForBattle
	goto_if_eq VAR_RESULT, FALSE, ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	call ViridianCity_Gym_EventScript_VerifyMemoryCleanupFlagsCleared
	goto_if_ne VAR_RESULT, TRUE, ViridianCity_Gym_EventScript_AbortGiovanniMemoryMode
	applymovement LOCALID_PLAYER, ViridianCity_Gym_Movement_PlayerBattleCue
	waitmovement 0
	delay 16
	trainerbattle_single TRAINER_LEADER_GIOVANNI, ViridianCity_Gym_Text_GiovanniIntro, ViridianCity_Gym_Text_GiovanniDefeat, ViridianCity_Gym_EventScript_DefeatedGiovanni, NO_MUSIC
	goto_if_set FLAG_GIO_MEM_CH3_COMPLETE, ViridianCity_Gym_EventScript_GiovanniMemoryPostBattle
	goto_if_unset FLAG_GOT_TM26_FROM_GIOVANNI, ViridianCity_Gym_EventScript_GiveTM26
	msgbox ViridianCity_Gym_Text_GiovanniPostBattle
	closemessage
	fadescreen FADE_TO_BLACK
	removeobject LOCALID_VIRIDIAN_GIOVANNI
	fadescreen FADE_FROM_BLACK
	release
	end


ViridianCity_Gym_EventScript_MemorySpaceMarker::
	goto_if_ne VAR_CHAPTER_ID, 3, ViridianCity_Gym_EventScript_MemorySpaceMarkerMismatch
	goto_if_set FLAG_GIO_MEM_CH3_COMPLETE, ViridianCity_Gym_EventScript_MemorySpaceMarkerComplete
