	goto_if_unset FLAG_ROCKETOPS_MILESTONE_CH1_LOGGED, ViridianCity_Gym_EventScript_GiovanniMemoryClosingMonologueFallback
	msgbox ViridianCity_Gym_Text_GiovanniMemoryMonologue_CH1Only
	goto_if_unset FLAG_ROCKETOPS_MILESTONE_CH2_LOGGED, ViridianCity_Gym_EventScript_GiovanniMemoryClosingMonologueApplyPause
	msgbox ViridianCity_Gym_Text_GiovanniMemoryMonologue_CH1CH2
