	goto_if_eq VAR_RESULT, GIO_SHARED_WARP_RESULT_LOCKED_FALLBACK, ViridianCity_Gym_EventScript_MemoryDesyncReturnToHub
	lockall
	msgbox ViridianCity_Gym_Text_MemoryExitBlocked
